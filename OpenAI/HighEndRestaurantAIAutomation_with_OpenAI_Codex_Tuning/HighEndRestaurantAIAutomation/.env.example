# Runtime
MOCK_MODE=true
APP_ENV=dev
LOG_LEVEL=INFO

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt4o-restaurant
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_INDEX=restaurant-knowledge-index

# Azure AI Services
AZURE_AI_SERVICES_ENDPOINT=https://your-ai-services.cognitiveservices.azure.com/
AZURE_LANGUAGE_ENDPOINT=https://your-language.cognitiveservices.azure.com/
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_SPEECH_REGION=eastus
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-contentsafety.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-docintelligence.cognitiveservices.azure.com/
AZURE_VISION_ENDPOINT=https://your-vision.cognitiveservices.azure.com/

# Key Vault
KEY_VAULT_URI=https://your-keyvault.vault.azure.net/

# Monitoring
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_ANALYTICS_WORKSPACE_ID=

# Optional Face / Custom Vision / Bot
AZURE_FACE_ENDPOINT=https://your-face.cognitiveservices.azure.com/
CUSTOM_VISION_ENDPOINT=https://your-customvision.cognitiveservices.azure.com/
BOT_APP_ID=
BOT_APP_PASSWORD=

# Azure environment variables for deploying/running the Azure High-End Restaurant AI Automation
# Keep secrets in Key Vault. These are defaults or placeholders for local dev.

# General
MOCK_MODE=true  # set false to use real Azure services (requires credentials)
ENVIRONMENT=development  # development|staging|production

# Azure AD (used by DefaultAzureCredential local dev or service principals)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Key Vault
KEY_VAULT_NAME=your-keyvault-name  # Key Vault where secrets are stored

# Azure OpenAI
OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/  # Azure OpenAI resource endpoint
OPENAI_DEPLOYMENT_CHAT=chat-deployment-name  # deployment name for chat models
OPENAI_DEPLOYMENT_EMBED=embedding-deployment-name  # deployment name for embeddings
# If using API key instead of managed identity
OPENAI_API_KEY=

# Azure Cognitive Search
SEARCH_SERVICE_NAME=your-search-service-name  # Cognitive Search service name
SEARCH_INDEX_NAME=restaurant-index  # default index name
SEARCH_API_KEY=

# Azure Document Intelligence
# Model IDs or project names for prebuilt/custom models
DOCINT_PROJECT_NAME=
DOCINT_DEPLOYMENT_NAME=

# Storage and ingestion
STORAGE_ACCOUNT_NAME=yourstorageacct
STORAGE_CONTAINER_NAME=docs
STORAGE_CONNECTION_STRING=

# Redis (Azure Cache for Redis or local)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# App Insights
APPINSIGHTS_INSTRUMENTATIONKEY=
APPINSIGHTS_CONNECTION_STRING=

# Durable Functions / Functions
FUNCTIONS_STORAGE_ACCOUNT_NAME=funcstorageacct
FUNCTIONS_APP_NAME=restaurant-func-app

# Telemetry, monitoring, and ops
LOG_LEVEL=INFO

# Optional: override CPU/memory or app settings
APP_MAX_WORKERS=4

# Notes:
# - For local development, set MOCK_MODE=true. To call Azure services set MOCK_MODE=false and provide
#   appropriate credentials (either via AZURE_* env vars for service principal or via az login to use DefaultAzureCredential).
# - Secrets like OPENAI_API_KEY, SEARCH_API_KEY and STORAGE_CONNECTION_STRING should be stored in Key Vault in production.
